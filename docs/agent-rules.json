{
  "schemaVersion": "2.0.0",
  "project": {
    "name": "fcmoim",
    "docs": {
      "readme": "docs/README.md",
      "decisions": "docs/decisions.md",
      "context": "docs/project-context.json",
      "designTokens": "docs/design-tokens.md",
      "feedback": "docs/agent-feedback.md"
    }
  },
  "agents": [
    {
      "id": "builder",
      "owns": ["src/**", "supabase/**", "public/**", "tests/**"],
      "forbidden": [".github/**", ".agents/**"]
    },
    {
      "id": "infra",
      "owns": ["AGENT.md", "docs/**", ".agents/**", ".github/**", "scripts/**", "package.json", "apphosting.yaml", "firebase.json", ".env.local.example"],
      "forbidden": []
    },
    {
      "id": "verifier",
      "owns": ["tests/**"],
      "forbidden": [".github/**", ".agents/**", "docs/project-context.json", "src/**", "supabase/**"]
    },
    {
      "id": "orchestrator",
      "owns": ["docs/project-context.json", "docs/agent-rules.json"],
      "forbidden": [".github/**", "src/**", "supabase/**"]
    }
  ],
  "sharedAllowedPaths": [".gitignore", "package-lock.json"],
  "surfaces": [
    { "id": "ui", "paths": ["src/app/**", "src/components/**", "src/stores/**"] },
    { "id": "api", "paths": ["src/app/api/**", "src/lib/**", "src/services/**"] },
    { "id": "data", "paths": ["supabase/**", "src/types/database.generated.ts", "src/types/database.types.ts"] },
    { "id": "docs", "paths": ["docs/**"] },
    { "id": "tests", "paths": ["tests/**"] },
    { "id": "infra", "paths": [".github/**", "apphosting.yaml", "firebase.json", "package.json", "scripts/**"] }
  ],
  "commands": {
    "baseline": "npm run verify:baseline",
    "verify": "npm run verify:harness",
    "preCommit": "npm run lint"
  },
  "guardProfiles": {
    "preCommit": { "steps": ["validateHarness", "guardDesignStaged", "projectPreCommit"] },
    "verify": { "steps": ["validateHarness", "guardDesign", "guardDiff", "projectVerify", "guardEvidence"] }
  },
  "statePolicy": {
    "writer": "orchestrator"
  },
  "completionPolicy": {
    "commitAtTurnEnd": true,
    "commitMessageLanguage": "ko",
    "splitLargeWorkByConcern": true,
    "summaryRequired": true
  },
  "retrospectivePolicy": {
    "requiredAtCompletion": true,
    "requiredFields": ["issuesObserved", "missedEvidence", "harnessImprovementProposal", "promotionRecommendation", "reason"],
    "promotionRecommendations": ["none", "propose", "defer"],
    "proposalOnlyByDefault": true,
    "promotionRequiresUserApproval": true
  },
  "documentationPolicy": {
    "maxLines": 200,
    "targetPatterns": ["AGENT.md", "docs/*.md", "docs/user/*.md", "docs/agent-rules.json", ".agents/manifest.json", ".agents/contracts/agent-contracts.json"],
    "excludePaths": ["docs/project-context.json"]
  },
  "assetProvenancePolicy": "When a user specifies an external asset URL, including SVGRepo assets, fetch or reference the original asset exactly and preserve provenance, or report the blocker; do not recreate, approximate, or transform it.",
  "evidencePolicy": {
    "ui": {
      "requiredEvidence": [{ "type": "deterministic", "maxAgeMinutes": 1440 }],
      "providers": ["Vitest", "Testing Library", "SDD acceptance tests"]
    },
    "api": {
      "requiredEvidence": [{ "type": "api", "maxAgeMinutes": 1440 }],
      "providers": ["Local Supabase CLI"],
      "mockEvidenceAccepted": false
    },
    "data": {
      "requiredEvidence": [{ "type": "database", "maxAgeMinutes": 1440 }],
      "providers": ["Local Supabase CLI", "tracked SQL"],
      "mockEvidenceAccepted": false
    },
    "browserSmoke": {
      "requiredEvidence": [{ "type": "runtime", "maxAgeMinutes": 1440 }],
      "providers": ["npm run dev", "in-app browser", "server terminal log"],
      "requiredWhenChanged": [
        "src/app/page.tsx",
        "src/app/layout.tsx",
        "src/lib/**",
        "src/services/**",
        "src/stores/useAuthStore.ts",
        "src/stores/membershipClient.ts",
        "src/app/api/**",
        "supabase/**",
        "package.json",
        "next.config.ts",
        "scripts/with-local-supabase-env.mjs"
      ],
      "packageReasonRequired": true,
      "packageReasonPaths": ["package.json"],
      "packageReasonTerms": ["runtime", "dependency", "dev-server", "startup", "module", "script", "package"],
      "minimum": "Start npm run dev, open http://localhost:3000/ in the in-app browser, confirm first-screen render, and confirm no app errors or avoidable startup warnings in the server terminal.",
      "notRequiredFor": ["copy-only UI changes", "documentation-only changes", "pure unit-test changes"]
    }
  },
  "reviewPolicy": {
    "required": true,
    "readyStatus": "ready"
  },
  "designPolicy": {
    "tokenDefinitionFiles": ["src/app/globals.css", "tailwind.config.ts"],
    "guardedPaths": ["src/app/**", "src/components/**"],
    "allowedTailwindColorPrefixes": [
      "brand", "fcgreen", "action", "border", "divider",
      "condition", "tier", "stat", "pos", "chem", "stamina", "foot", "viz",
      "attend", "result", "matchst", "award", "fee", "skill", "trend", "feedback",
      "gray", "slate", "green", "white", "black",
      "red-team", "blue-team", "background", "foreground", "transparent", "current", "event",
      "highlight", "metric", "social"
    ],
    "customSvgAllowedPaths": ["src/components/brand/**", "src/components/ui/**", "src/components/icons/**"],
    "exemptPatterns": ["// design-exempt"],
    "layoutPolicy": {
      "forbiddenClasses": ["overflow-x-auto", "overflow-x-scroll"],
      "forbidArbitraryMinWidth": true
    },
    "inAppInstructionPolicy": {
      "forbiddenPatterns": ["드래그하세요", "클릭하세요", "첫 선수는 주장입니다", "사용법"]
    },
    "semanticSlots": [
      {
        "id": "locker-room-squad-condition",
        "description": "Locker room squad condition indicators must use the shared condition icon and condition-* tokens.",
        "paths": ["src/components/tabs/LockerRoomTab.tsx"],
        "requiredContent": ["ConditionIcon", "getDisplayCondition"],
        "forbiddenContent": ["CircleCheck", "컨디션 정상"]
      },
      {
        "id": "condition-icon-token-contract",
        "description": "The shared condition icon must expose the five condition token styles.",
        "paths": ["src/components/ui/ConditionIcon.tsx"],
        "requiredContent": ["text-condition-best", "text-condition-good", "text-condition-normal", "text-condition-poor", "text-condition-worst"],
        "forbiddenContent": ["text-green-600", "text-red-500", "text-blue-500"]
      }
    ],
    "docs": "docs/design-tokens.md"
  },
  "scopeControlPolicy": {
    "uiSensitivePaths": ["src/app/**", "src/components/**", "src/stores/**", "public/**"]
  },
  "loopPolicy": {
    "maxGuardRetries": 3,
    "maxReviewRounds": 3,
    "escalationAction": "Stop work and report to user with: (1) current state summary, (2) failure analysis, (3) next step suggestions"
  },
  "harnessPurity": {
    "forbiddenTokens": ["fcmoim", "npm", "src/", "tests/", "supabase", "Next.js", "Firebase", "docs/README", "docs/project-context", "docs/decisions"]
  }
}
