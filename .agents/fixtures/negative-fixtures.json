{
  "schemaVersion": "2.0.0",
  "cases": [
    {
      "id": "design-guard-hardcoded-hex",
      "description": "guard-design rejects hardcoded hex color in guarded path",
      "command": "node .agents/scripts/guard-design.mjs",
      "mutations": [
        { "path": "app/view/Widget.tsx", "content": "export default function Widget() { return <div style={{ color: '#ff0000' }}>test</div>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "design-guard-all-mode-hardcoded-hex",
      "description": "guard-design --all scans the full guarded file set",
      "command": "node .agents/scripts/guard-design.mjs --all",
      "mutations": [
        { "path": "app/view/AllWidget.tsx", "content": "export default function AllWidget() { return <div style={{ color: '#ff0000' }}>test</div>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "design-guard-semantic-slot-condition",
      "description": "guard-design rejects a condition UI slot that uses a generic green check icon",
      "command": "node .agents/scripts/guard-design.mjs",
      "mutations": [
        { "path": "app/view/Locker.tsx", "content": "import { CircleCheck } from 'lucide-react';\nexport default function Locker() { return <div><span>컨디션</span><CircleCheck className=\"text-green-600\" aria-label=\"컨디션 정상\" /></div>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "design-guard-horizontal-scroll",
      "description": "guard-design rejects horizontal scroll utilities and arbitrary min-width",
      "command": "node .agents/scripts/guard-design.mjs",
      "mutations": [
        { "path": "app/view/WideTable.tsx", "content": "export default function WideTable() { return <div className=\"overflow-x-auto\"><div className=\"min-w-[620px]\">wide</div></div>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "design-guard-instructional-copy",
      "description": "guard-design rejects visible how-to copy in product UI",
      "command": "node .agents/scripts/guard-design.mjs",
      "mutations": [
        { "path": "app/view/Instruction.tsx", "content": "export default function Instruction() { return <p>썸네일을 Red/Blue 박스에 드래그하세요.</p>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "diff-guard-outside-allowed-paths",
      "description": "guard-diff rejects changed files outside allowed paths",
      "command": "node .agents/scripts/guard-diff.mjs",
      "mutations": [
        { "path": "forbidden/change.txt", "content": "change" }
      ],
      "expectedExit": 1
    },
    {
      "id": "evidence-guard-browser-smoke-missing",
      "description": "guard-evidence rejects ready work when browser smoke is required but missing",
      "command": "node .agents/scripts/guard-evidence.mjs",
      "rulesPatch": {
        "evidencePolicy": {
          "browserSmoke": {
            "requiredEvidence": [{ "type": "runtime", "maxAgeMinutes": 1440 }],
            "providers": ["Runtime Browser"],
            "requiredWhenChanged": ["app/runtime/**"]
          }
        },
        "retrospectivePolicy": {
          "requiredAtCompletion": true,
          "requiredFields": ["issuesObserved", "missedEvidence", "harnessImprovementProposal", "promotionRecommendation", "reason"],
          "promotionRecommendations": ["none", "propose", "defer"]
        }
      },
      "statePatch": {
        "activeWork": {
          "status": "complete",
          "changedFiles": ["app/runtime/session.ts"],
          "changedSurfaces": ["interface"],
          "allowedPaths": ["app/runtime/**"],
          "evidence": {},
          "reviewStatus": "ready",
          "retrospective": {
            "issuesObserved": [],
            "missedEvidence": ["browserRuntime"],
            "harnessImprovementProposal": [],
            "promotionRecommendation": "none",
            "reason": "Fixture retrospective present."
          }
        }
      },
      "mutations": [
        { "path": "app/runtime/session.ts", "content": "export const value = true;\n" }
      ],
      "expectedExit": 1
    },
    {
      "id": "evidence-guard-browser-smoke-present",
      "description": "guard-evidence accepts ready work when required browser smoke passed",
      "command": "node .agents/scripts/guard-evidence.mjs",
      "rulesPatch": {
        "evidencePolicy": {
          "browserSmoke": {
            "requiredEvidence": [{ "type": "runtime", "maxAgeMinutes": 1440 }],
            "providers": ["Runtime Browser"],
            "requiredWhenChanged": ["app/runtime/**"]
          }
        },
        "retrospectivePolicy": {
          "requiredAtCompletion": true,
          "requiredFields": ["issuesObserved", "missedEvidence", "harnessImprovementProposal", "promotionRecommendation", "reason"],
          "promotionRecommendations": ["none", "propose", "defer"]
        }
      },
      "statePatch": {
        "activeWork": {
          "status": "complete",
          "changedFiles": ["app/runtime/session.ts"],
          "changedSurfaces": ["interface"],
          "allowedPaths": ["app/runtime/**"],
          "evidence": {
            "browserRuntime": {
              "status": "passed",
              "provider": "Runtime Browser",
              "summary": "First screen rendered and server output stayed clean."
            }
          },
          "reviewStatus": "ready",
          "retrospective": {
            "issuesObserved": [],
            "missedEvidence": [],
            "harnessImprovementProposal": [],
            "promotionRecommendation": "none",
            "reason": "Fixture retrospective present."
          }
        }
      },
      "mutations": [
        { "path": "app/runtime/session.ts", "content": "export const value = true;\n" }
      ],
      "expectedExit": 0
    },
    {
      "id": "evidence-guard-browser-smoke-blocked",
      "description": "guard-evidence accepts non-ready blocked work with an explicit missing evidence blocker",
      "command": "node .agents/scripts/guard-evidence.mjs",
      "rulesPatch": {
        "evidencePolicy": {
          "browserSmoke": {
            "requiredEvidence": [{ "type": "runtime", "maxAgeMinutes": 1440 }],
            "providers": ["Runtime Browser"],
            "requiredWhenChanged": ["app/runtime/**"]
          }
        },
        "retrospectivePolicy": {
          "requiredAtCompletion": true,
          "requiredFields": ["issuesObserved", "missedEvidence", "harnessImprovementProposal", "promotionRecommendation", "reason"],
          "promotionRecommendations": ["none", "propose", "defer"]
        }
      },
      "statePatch": {
        "activeWork": {
          "status": "blocked",
          "changedFiles": ["app/runtime/session.ts"],
          "changedSurfaces": ["interface"],
          "allowedPaths": ["app/runtime/**"],
          "evidence": {},
          "reviewStatus": "blocked",
          "retrospective": {
            "issuesObserved": ["Required browser evidence could not be collected."],
            "missedEvidence": ["browserRuntime"],
            "harnessImprovementProposal": [],
            "promotionRecommendation": "defer",
            "reason": "Fixture records unavailable evidence as a blocker."
          }
        },
        "blockers": [
          { "id": "missing-browserRuntime", "reason": "Required browserRuntime evidence tool unavailable." }
        ]
      },
      "mutations": [
        { "path": "app/runtime/session.ts", "content": "export const value = true;\n" }
      ],
      "expectedExit": 0
    }
  ]
}
