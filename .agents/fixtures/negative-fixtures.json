{
  "schemaVersion": "2.0.0",
  "cases": [
    {
      "id": "design-guard-hardcoded-hex",
      "description": "guard-design rejects hardcoded hex color in guarded path",
      "command": "node .agents/scripts/guard-design.mjs",
      "mutations": [
        { "path": "app/view/Widget.tsx", "content": "export default function Widget() { return <div style={{ color: '#ff0000' }}>test</div>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "design-guard-redesign-color-warning",
      "description": "guard-design allows unregistered Tailwind color prefix as warning in redesign mode",
      "command": "node .agents/scripts/guard-design.mjs",
      "statePatch": {
        "activeWork": {
          "designMode": "redesign"
        }
      },
      "mutations": [
        { "path": "app/view/ExperimentalCard.tsx", "content": "export default function ExperimentalCard() { return <div className=\"bg-blue-500 text-gray-900\">test</div>; }" }
      ],
      "expectedExit": 0
    },
    {
      "id": "design-guard-redesign-hardcoded-hex",
      "description": "guard-design still rejects hardcoded hex color in redesign mode",
      "command": "node .agents/scripts/guard-design.mjs",
      "statePatch": {
        "activeWork": {
          "designMode": "redesign"
        }
      },
      "mutations": [
        { "path": "app/view/ExperimentalHex.tsx", "content": "export default function ExperimentalHex() { return <div style={{ color: '#ff0000' }}>test</div>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "design-guard-all-mode-hardcoded-hex",
      "description": "guard-design --all scans the full guarded file set",
      "command": "node .agents/scripts/guard-design.mjs --all",
      "mutations": [
        { "path": "app/view/AllWidget.tsx", "content": "export default function AllWidget() { return <div style={{ color: '#ff0000' }}>test</div>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "design-guard-semantic-slot-condition",
