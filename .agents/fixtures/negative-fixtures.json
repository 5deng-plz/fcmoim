{
  "schemaVersion": "1.0.0",
  "cases": [
    {
      "id": "forbidden-path",
      "command": "node .agents/scripts/guard-diff.mjs --agent=writer",
      "mutations": [
        {
          "path": "app/blocked/change.txt",
          "content": "change"
        }
      ],
      "expectedExit": 1
    },
    {
      "id": "active-allowed-path-cannot-override-forbidden",
      "command": "node .agents/scripts/guard-diff.mjs --agent=writer",
      "mutations": [
        {
          "path": "app/blocked/explicitly-allowed.txt",
          "content": "change"
        }
      ],
      "statePatch": {
        "activeWork": {
          "allowedPaths": [
            "app/blocked/explicitly-allowed.txt",
            "docs/state.json"
          ]
        }
      },
      "expectedExit": 1
    },
