      "command": "node .agents/scripts/guard-design.mjs",
      "mutations": [
        { "path": "app/view/WideTable.tsx", "content": "export default function WideTable() { return <div className=\"overflow-x-auto\"><div className=\"min-w-[620px]\">wide</div></div>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "design-guard-redesign-horizontal-scroll",
      "description": "guard-design rejects layout blockers even in redesign mode",
      "command": "node .agents/scripts/guard-design.mjs",
      "statePatch": {
        "activeWork": {
          "designMode": "redesign"
        }
      },
      "mutations": [
        { "path": "app/view/RedesignWideTable.tsx", "content": "export default function RedesignWideTable() { return <div className=\"overflow-x-auto\"><div className=\"min-w-[620px]\">wide</div></div>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "design-guard-instructional-copy",
      "description": "guard-design rejects visible how-to copy in product UI",
      "command": "node .agents/scripts/guard-design.mjs",
      "mutations": [
        { "path": "app/view/Instruction.tsx", "content": "export default function Instruction() { return <p>썸네일을 Red/Blue 박스에 드래그하세요.</p>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "design-guard-expired-exempt",
      "description": "guard-design rejects expired design-exempt metadata",
      "command": "node .agents/scripts/guard-design.mjs",
      "rulesPatch": {
        "designPolicy": {
          "exemptPatterns": ["design-exempt"]
        }
      },
      "mutations": [
        { "path": "app/view/ExpiredExempt.tsx", "content": "export default function ExpiredExempt() { return <div className=\"bg-blue-500\">test</div>; } // design-exempt(reason: temporary-redesign-spike, expires: 2020-01-01)" }
      ],
      "expectedExit": 1
    },
    {
      "id": "token-sync-drift",
      "description": "guard-token-sync rejects documented token prefixes missing from agent rules",
      "command": "node .agents/scripts/guard-token-sync.mjs",
      "mutations": [
        { "path": "docs/design-tokens.md", "content": "# Tokens\n\n- `glass-*` — glass card tokens\n" }
      ],
      "expectedExit": 1
    },
    {
      "id": "semantic-slot-metadata-missing",
      "description": "validate-harness rejects semantic slots without durable metadata",
      "command": "node .agents/scripts/validate-harness.mjs",
      "rulesPatch": {
        "designPolicy": {
          "semanticSlots": [
            {
              "id": "missing-metadata-slot",
              "paths": ["app/view/Locker.tsx"],
              "requiredContent": ["ConditionIcon"],
              "forbiddenContent": []
            }
          ]
        }
      },
      "expectedExit": 1
    },
    {
      "id": "diff-guard-outside-allowed-paths",
      "description": "guard-diff rejects changed files outside allowed paths",
      "command": "node .agents/scripts/guard-diff.mjs",
      "mutations": [
        { "path": "forbidden/change.txt", "content": "change" }
      ],
      "expectedExit": 1
    },
    {
      "id": "evidence-guard-redesign-visual-review-missing",
      "description": "guard-evidence rejects ready redesign UI work without visualReview evidence",
      "command": "node .agents/scripts/guard-evidence.mjs",
      "statePatch": {
        "activeWork": {
          "status": "complete",
          "designMode": "redesign",
          "changedFiles": ["app/view/ExperimentalCard.tsx"],
          "changedSurfaces": ["interface"],
          "allowedPaths": ["app/view/**"],
          "evidence": {},
          "reviewStatus": "ready",
          "retrospective": {
            "issuesObserved": [],
            "missedEvidence": ["visualReview"],
            "harnessImprovementProposal": [],
            "promotionRecommendation": "none",
            "reason": "Fixture retrospective present."
          }
        }
      },
      "mutations": [
        { "path": "app/view/ExperimentalCard.tsx", "content": "export default function ExperimentalCard() { return <div className=\"bg-gray-100\">test</div>; }" }
      ],
      "expectedExit": 1
    },
    {
      "id": "evidence-guard-browser-smoke-missing",
      "description": "guard-evidence rejects ready work when browser smoke is required but missing",
      "command": "node .agents/scripts/guard-evidence.mjs",
      "rulesPatch": {
        "evidencePolicy": {
          "browserSmoke": {
            "requiredEvidence": [{ "type": "runtime", "maxAgeMinutes": 1440 }],
            "providers": ["Runtime Browser"],
            "requiredWhenChanged": ["app/runtime/**"]
          }
        },
        "retrospectivePolicy": {
          "requiredAtCompletion": true,
          "requiredFields": ["issuesObserved", "missedEvidence", "harnessImprovementProposal", "promotionRecommendation", "reason"],
          "promotionRecommendations": ["none", "propose", "defer"]
        }
      },
      "statePatch": {
        "activeWork": {
          "status": "complete",
          "changedFiles": ["app/runtime/session.ts"],
          "changedSurfaces": ["interface"],
          "allowedPaths": ["app/runtime/**"],
          "evidence": {},
          "reviewStatus": "ready",
          "retrospective": {
            "issuesObserved": [],
            "missedEvidence": ["browserRuntime"],
            "harnessImprovementProposal": [],
            "promotionRecommendation": "none",
            "reason": "Fixture retrospective present."
          }
        }
      },
      "mutations": [
        { "path": "app/runtime/session.ts", "content": "export const value = true;\n" }
      ],
      "expectedExit": 1
    },
    {
      "id": "evidence-guard-browser-smoke-present",
      "description": "guard-evidence accepts ready work when required browser smoke passed",
      "command": "node .agents/scripts/guard-evidence.mjs",
      "rulesPatch": {
        "evidencePolicy": {
          "browserSmoke": {
            "requiredEvidence": [{ "type": "runtime", "maxAgeMinutes": 1440 }],
            "providers": ["Runtime Browser"],
            "requiredWhenChanged": ["app/runtime/**"]
          }
        },
        "retrospectivePolicy": {
          "requiredAtCompletion": true,
          "requiredFields": ["issuesObserved", "missedEvidence", "harnessImprovementProposal", "promotionRecommendation", "reason"],
          "promotionRecommendations": ["none", "propose", "defer"]
        }
      },
      "statePatch": {
        "activeWork": {
          "status": "complete",
          "changedFiles": ["app/runtime/session.ts"],
          "changedSurfaces": ["interface"],
          "allowedPaths": ["app/runtime/**"],
          "evidence": {
            "browserRuntime": {
              "status": "passed",
              "provider": "Runtime Browser",
              "summary": "First screen rendered and server output stayed clean."
            }
          },
          "reviewStatus": "ready",
          "retrospective": {
            "issuesObserved": [],
            "missedEvidence": [],
            "harnessImprovementProposal": [],
            "promotionRecommendation": "none",
            "reason": "Fixture retrospective present."
          }
        }
      },
      "mutations": [
        { "path": "app/runtime/session.ts", "content": "export const value = true;\n" }
      ],
      "expectedExit": 0
    },
    {
      "id": "evidence-guard-browser-smoke-blocked",
      "description": "guard-evidence accepts non-ready blocked work with an explicit missing evidence blocker",
      "command": "node .agents/scripts/guard-evidence.mjs",
      "rulesPatch": {
        "evidencePolicy": {
          "browserSmoke": {
            "requiredEvidence": [{ "type": "runtime", "maxAgeMinutes": 1440 }],
            "providers": ["Runtime Browser"],
            "requiredWhenChanged": ["app/runtime/**"]
          }
        },
        "retrospectivePolicy": {
          "requiredAtCompletion": true,
          "requiredFields": ["issuesObserved", "missedEvidence", "harnessImprovementProposal", "promotionRecommendation", "reason"],
          "promotionRecommendations": ["none", "propose", "defer"]
        }
      },
      "statePatch": {
        "activeWork": {
          "status": "blocked",
          "changedFiles": ["app/runtime/session.ts"],
          "changedSurfaces": ["interface"],
          "allowedPaths": ["app/runtime/**"],
          "evidence": {},
          "reviewStatus": "blocked",
          "retrospective": {
            "issuesObserved": ["Required browser evidence could not be collected."],
            "missedEvidence": ["browserRuntime"],
            "harnessImprovementProposal": [],
            "promotionRecommendation": "defer",
            "reason": "Fixture records unavailable evidence as a blocker."
          }
        },
        "blockers": [
          { "id": "missing-browserRuntime", "reason": "Required browserRuntime evidence tool unavailable." }
        ]
      },
      "mutations": [
        { "path": "app/runtime/session.ts", "content": "export const value = true;\n" }
      ],
      "expectedExit": 0
    },
