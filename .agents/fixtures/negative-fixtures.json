    {
      "id": "invalid-allowed-path-lease-policy",
      "description": "validate-project-rules rejects malformed allowed path lease policy",
      "command": "node .agents/scripts/validate-project-rules.mjs",
      "rulesPatch": {
        "coordinationPolicy": {
          "allowedPathLeases": {
            "source": "activeWork.changedFiles"
          }
        }
      },
      "expectedExit": 1
    },
    {
      "id": "design-guard-hardcoded-hex",
      "description": "guard-design rejects hardcoded hex color in guarded path",
      "command": "node .agents/scripts/guard-design.mjs",
      "mutations": [
        {
          "path": "app/view/Widget.tsx",
          "content": "export default function Widget() { return <div style={{ color: '#ff0000' }}>test</div>; }"
        }
      ],
      "statePatch": {},
      "expectedExit": 1
    },
    {
      "id": "design-guard-all-mode-hardcoded-hex",
