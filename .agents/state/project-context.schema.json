{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Project Context (Lightweight)",
  "type": "object",
  "required": ["schemaVersion", "projectName", "updateVersion", "updatedAt", "updatedBy", "currentPhase", "activeWork"],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "projectName": { "type": "string", "minLength": 1 },
    "updateVersion": { "type": "integer", "minimum": 0 },
    "updatedAt": { "type": "string", "minLength": 1 },
    "updatedBy": { "type": "string" },
    "currentPhase": { "type": "string", "minLength": 1 },
    "activeWork": {
      "type": "object",
      "required": ["taskId", "status", "changedFiles", "changedSurfaces", "allowedPaths"],
      "properties": {
        "taskId": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "baselineCommit": { "type": ["string", "null"] },
        "changedFiles": { "type": "array", "items": { "type": "string" } },
        "changedSurfaces": { "type": "array", "items": { "type": "string" } },
        "allowedPaths": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "object" },
        "reviewStatus": { "type": ["string", "null"] },
        "loopCounters": {
          "type": "object",
          "properties": {
            "reviewRounds": { "type": "integer", "minimum": 0 },
            "guardRetries": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "workstreams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "completedAt": { "type": ["string", "null"] },
          "commit": { "type": ["string", "null"] }
        }
      }
    },
    "blockers": { "type": "array" },
    "nextActions": { "type": "array" }
  },
  "additionalProperties": true
}
