# Firebase
NEXT_PUBLIC_FIREBASE_PUBLIC_CONFIG='{"apiKey":"","authDomain":"","projectId":"","messagingSenderId":"","appId":"","vapidKey":""}'

# Optional split Firebase fallback vars used when NEXT_PUBLIC_FIREBASE_PUBLIC_CONFIG is empty.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_PUBLIC_CONFIG='{"url":"","publishableKey":""}'
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Server-side comment event delivery. Use disabled for an emergency fallback.
COMMENT_REALTIME_PROVIDER=supabase

# Kakao
# Current app code starts Kakao OAuth through Supabase Auth. Configure the Kakao
# REST API key, client secret, and redirect URI in Supabase/Kakao dashboards.
KAKAO_OAUTH_CONFIG=

# Google OAuth
# Current app code starts Google OAuth through Supabase Auth. Configure a Google
# Web application OAuth client, add the Supabase Auth callback URL in Google
# Cloud, and add the Client ID/Secret in Supabase Auth provider settings.
# Local Supabase callback URL: http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

# App
APP_PROFILE=local
NEXT_PUBLIC_APP_PROFILE=local
# Server-only launch mode. Multi-club APIs stay hidden unless explicitly enabled.
MULTI_CLUB_ENABLED=false
# Fixed provider team id used while multi-club mode is disabled.
FC_GUPPY_CLUB_ID=00000000-0000-0000-0000-000000000001
# Frontend compatibility display value only. Never use for authorization.
NEXT_PUBLIC_DEFAULT_CLUB_ID=00000000-0000-0000-0000-000000000001
DEV_TEST=false
# Local QA accounts use this password in seed and API smoke tests.
QA_LOCAL_ACCOUNT_PASSWORD=password
